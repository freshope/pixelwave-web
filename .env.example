# Postgres (Coolify postgres-shared 내부 hostname, DB/user: pixelwave)
DATABASE_URL=postgresql://pixelwave:<password>@postgres-shared:5432/pixelwave

# Auth.js v5 (NextAuth)
AUTH_SECRET=<openssl rand -base64 32>
AUTH_URL=https://pixelwave.app
AUTH_TRUST_HOST=true

# GitHub OAuth App (callback: https://pixelwave.app/api/auth/callback/github)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Admin 화이트리스트 — 쉼표 구분된 GitHub numeric ID (예: 12345,67890)
# 본인 GitHub 의 numeric id: https://api.github.com/users/<username>
ADMIN_GITHUB_IDS=
