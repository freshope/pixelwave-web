// Cloudflare Workers (Static Assets) 배포 설정.
// CF 대시보드의 deploy command 가 `npx wrangler versions upload` 일 때 필요.
// 이 파일은 wrangler 가 자동으로 자산 업로드 대상에서 제외한다.
//
// `_worker.js` 는 `/invite` UA 분기 리다이렉트를 처리하고 그 외 경로는 ASSETS 로 fall-through.
// `_` 접두사 파일은 자산 업로드에서 자동 제외된다.
{
  "name": "pixelwave-today-alive",
  "compatibility_date": "2026-05-19",
  "main": "_worker.js",
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  }
}
